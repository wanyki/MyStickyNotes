<Window x:Class="MyStickyNotes.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="备忘录" Height="300" Width="250"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        ShowInTaskbar="False" ResizeMode="CanResizeWithGrip">

    <Window.Resources>
        <Style TargetType="{x:Type ScrollBar}">
            <Setter Property="Width" Value="6"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ScrollBar}">
                        <Grid>
                            <Border Background="Transparent"/>
                            <Track x:Name="PART_Track" IsDirectionReversed="true">
                                <Track.Thumb>
                                    <Thumb>
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Border Background="#88FFFFFF" CornerRadius="3" Margin="0,2,0,2"/>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border BorderThickness="1" BorderBrush="#66FFFFFF" Background="#33000000">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="35"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Background="Transparent" MouseLeftButtonDown="Window_MouseLeftButtonDown">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock Text="T" Background="#FF68A32C" Foreground="White" Padding="4,0" Margin="0,0,5,0" FontWeight="Bold" VerticalAlignment="Center"/>
                    <TextBox x:Name="TitleBox" Text="备忘" Foreground="White" Background="Transparent" BorderThickness="0" FontSize="14" MaxWidth="150" VerticalAlignment="Center" LostFocus="TitleBox_LostFocus">
                        <TextBox.Effect>
                            <DropShadowEffect ShadowDepth="1" BlurRadius="2" Color="Black" Opacity="0.8"/>
                        </TextBox.Effect>
                    </TextBox>
                    <Button x:Name="LockButton" Content="🔓" Background="Transparent" BorderThickness="0" Foreground="White" Margin="10,0,0,0" Click="LockButton_Click" Cursor="Hand" FontSize="12"/>
                </StackPanel>
            </Grid>

            <ListBox x:Name="MemoList" Grid.Row="1" 
                     Background="Transparent" BorderThickness="0" 
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                     VirtualizingStackPanel.IsVirtualizing="False"
                     HorizontalContentAlignment="Stretch"
                     PreviewMouseLeftButtonDown="MemoList_PreviewMouseLeftButtonDown">
            </ListBox>
        </Grid>
    </Border>
</Window>